<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IDPBookApp.Pages.Registro"
             xmlns:viewmodel="clr-namespace:IDPBookApp.ViewModel"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:DataType="viewmodel:NewPacViewModel"
             Title="Registro">
    <ScrollView>
        <VerticalStackLayout Spacing="0">
            <ImageButton Source="back2" Aspect="Fill" WidthRequest="30" HeightRequest="30" HorizontalOptions="Start" Margin="20,20,0,0" Command="{Binding BackBtnCommand}">
                <ImageButton.Behaviors>
                    <toolkit:IconTintColorBehavior TintColor="#28B463" />
                </ImageButton.Behaviors>
            </ImageButton>
            <Label Text="REGISTRO USUARIOS" FontSize="Large" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,-30,0,0"/>

            <Border Margin="10,20" Padding="10" VerticalOptions="Center">
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="50,Auto,auto,Auto,auto,auto,auto,Auto,auto,auto,auto,auto,auto,auto,80" RowSpacing="5">
                    <Label Text="Tipo:" FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="Start"/>
                    <Label Text="Paciente" Grid.Column="1" FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="Start"/>
                    <CheckBox IsChecked="{Binding Dsbl}" CheckedChanged="CheckBox_CheckedChanged0" Grid.Column="1" VerticalOptions="Center" HorizontalOptions="Start" Margin="45,0,0,0"/>
                    <Label Text="Personal médico " Grid.Column="1" FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="Center" Margin="45,0,0,0"/>
                    <CheckBox x:Name="check1" CheckedChanged="CheckBox_CheckedChanged1" Grid.Column="1" VerticalOptions="Center" HorizontalOptions="Center" Margin="175,0,0,0"/>

                    <Label Grid.Row="1" Text="Nombre:   " FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="Start"/>
                    <Entry Grid.Row="1" Text="{Binding NombPac}" Grid.Column="1" VerticalOptions="Center" HorizontalOptions="Fill" Placeholder="Ingresa nombre" HorizontalTextAlignment="Start"  HeightRequest="35" Keyboard="Text" ReturnType="Go"/>

                    <Label Grid.Row="2" Text="Apellidos:" FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="Start" IsVisible="{Binding Dsbl}"/>
                    <Entry Text="{Binding ApllPac}" Grid.Row="2" Grid.Column="1" VerticalOptions="Center" HorizontalOptions="Fill" IsVisible="{Binding Dsbl}" Placeholder="Ingresa apellidos" HorizontalTextAlignment="Start"  HeightRequest="35" Keyboard="Text" ReturnType="Go"/>

                    <Label Grid.Row="3" Text="Correo:" FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="Start"/>
                    <Entry Text="{Binding EmailPac}" Grid.Row="3" Grid.Column="1" VerticalOptions="Center" HorizontalOptions="Fill" Placeholder="Ingresa correo" HorizontalTextAlignment="Start"  HeightRequest="35" Keyboard="Email" ReturnType="Go"/>

                    <Label Grid.Row="4" Text="Sexo:" FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="Start" IsVisible="{Binding Dsbl}"/>
                    <Picker Grid.Row="4" Grid.Column="1" Title="▼ Seleccionar sexo"  HeightRequest="35" SelectedItem="{Binding SexG}" IsVisible="{Binding Dsbl}">
                        <Picker.Items>
                            <x:String>femenino</x:String>
                            <x:String>masculino</x:String>
                            <x:String>indiferente</x:String>
                        </Picker.Items>
                    </Picker>

                    <Label Grid.Row="5" Text="Fecha Nac. " FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="Start" IsVisible="{Binding Dsbl}"/>
                    <DatePicker Date="{Binding FNac}" DateSelected="DatePicker_DateSelected"  CharacterSpacing="2" Format="d" Grid.Row="5" Grid.Column="1" HorizontalOptions="Start" IsVisible="{Binding Dsbl}"/>

                    <Label Grid.Row="6" Text="Edad:" FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="Start" IsVisible="{Binding Dsbl}"/>
                    <Entry Text="{Binding EdadPac}" Grid.Row="6" Grid.Column="1" VerticalOptions="Center" HorizontalOptions="Fill" Placeholder="Ingresa correo" HorizontalTextAlignment="Start"  HeightRequest="35" IsVisible="{Binding Dsbl}" IsEnabled="False"/>

                    <Label Grid.Row="7" Text="Diagnóstico:  " FontAttributes="Bold" VerticalOptions="Start" HorizontalOptions="Start" Margin="0,10,0,0" IsVisible="{Binding Dsbl}"/>
                    <Picker IsVisible="{Binding Dsbl}" SelectedIndex="{Binding DiagPpal}" Grid.Row="7" Grid.Column="1" Title="▼ Seleccionar diagnostico"  HorizontalOptions="Fill" VerticalOptions="Center">
                        <Picker.Items>
                            <x:String>Inmunodeficiencia Común Variable</x:String>
                            <x:String>Agammaglobulinemia ligada al X</x:String>
                            <x:String>Déficit de IgA</x:String>
                            <x:String>Déficit de subclases IgG</x:String>
                            <x:String>Déficit de respuesta a antígenos específicos</x:String>
                            <x:String>Inmunodeficiencia combinada</x:String>
                            <x:String>Enfermedad Granulomatosa Crónica</x:String>
                            <x:String>Microdelección 22q</x:String>
                            <x:String>Síndrome de Wiscott-Aldrich</x:String>
                            <x:String>Síndrome de Hiper-IgE</x:String>
                            <x:String>Síndrome de Hiper-IgM</x:String>
                            <x:String>ALPS</x:String>
                            <x:String>Candidiasis Mucocutanea Crónica</x:String>
                            <x:String>Otro</x:String>
                        </Picker.Items>
                    </Picker>

                    <Label IsVisible="{Binding FVsbl}" Grid.Row="8" Text="Fecha Diag." FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="Start" />
                    <DatePicker IsVisible="{Binding FVsbl}" Date="{Binding FDiag}" CharacterSpacing="2" Format="d" Grid.Row="8" Grid.Column="1" HorizontalOptions="Start" />

                    <Label Grid.Row="9" Text="Otro Diag. 1:" FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="Start" IsVisible="{Binding DiagVsbl}"/>
                    <Entry Text="{Binding OtroDiag1}" IsVisible="{Binding DiagVsbl}" Grid.Row="9" Grid.Column="1" VerticalOptions="Center" HorizontalOptions="Fill" Placeholder="Ingresa otro diagnostico 1" HorizontalTextAlignment="Start"  HeightRequest="35" ReturnType="Next"/>

                    <Label Grid.Row="10" Text="Fecha Diag. 1:  " FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="Start" IsVisible="{Binding DiagVsbl}"/>
                    <DatePicker Date="{Binding FDiag1}" IsVisible="{Binding DiagVsbl}" CharacterSpacing="2" Format="d" Grid.Row="10" Grid.Column="1" HorizontalOptions="Start" />

                    <Label Grid.Row="11" Text="Otro Diag. 2:" FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="Start" IsVisible="{Binding DiagVsbl}"/>
                    <Entry Text="{Binding OtroDiag2}" IsVisible="{Binding DiagVsbl}" Grid.Row="11" Grid.Column="1" VerticalOptions="Center" HorizontalOptions="Fill" Placeholder="Ingresa otro diagnostico 2" HorizontalTextAlignment="Start"  HeightRequest="35" ReturnType="Next"/>

                    <Label Grid.Row="12" Text="Fecha Diag. 2:" FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="Start" IsVisible="{Binding DiagVsbl}"/>
                    <DatePicker Date="{Binding FDiag2}" IsVisible="{Binding DiagVsbl}" CharacterSpacing="2" Format="d" Grid.Row="12" Grid.Column="1" HorizontalOptions="Start" />

                    <Label Grid.Row="13" Text="Centro:" FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="Start"/>
                    <Picker SelectedIndex="{Binding Centro}" Grid.Row="13" Grid.Column="1" Title="▼ Seleccionar centro médico"  HorizontalOptions="Fill" VerticalOptions="Center">
                        <Picker.Items>
                            <x:String>Hospital Universitario La Paz</x:String>
                            <x:String>Hospital Gregorio Marañón</x:String>
                            <x:String>Hospital General de Alicante</x:String>
                            <x:String>Hospital Reína Sofía</x:String>
                            <x:String>Hospital Dr. Negrín</x:String>
                            <x:String>Hospital Universitario de Puerto Real</x:String>
                            <x:String>Hospital de Bellvitge</x:String>
                            <x:String>Hospital Germans Trias i Pujol</x:String>
                            <x:String>Hospital Universitari i Politècnic La Fe</x:String>
                            <x:String>Hospital Universitario de Cruces</x:String>
                            <x:String>Hospital del Mar</x:String>
                            <x:String>Hospital Sant Joan de Deu</x:String>
                            <x:String>Hospital Universitario Lozano Blesa</x:String>
                        </Picker.Items>
                    </Picker>

                    <Button Grid.Row="14" Grid.Column="0" Grid.ColumnSpan="2" HorizontalOptions="Center" Margin="-100,0,0,0" Text="Agregar" WidthRequest="90" HeightRequest="45" Command="{Binding NewUserCommand}"/>
                    <Button Grid.Row="14" Grid.Column="0" Grid.ColumnSpan="2" HorizontalOptions="Center" Margin="100,0,0,0" Text="Salir" BackgroundColor="#E67E22" WidthRequest="90" HeightRequest="45" Command="{Binding BackBtnCommand}"/>
                </Grid>
            </Border>
            <ActivityIndicator IsRunning="{Binding Run}" Margin="10" HorizontalOptions="Center"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>