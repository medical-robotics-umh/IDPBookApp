<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IDPBookApp.Pages.LoginPage"
             xmlns:model="clr-namespace:IDPBookApp.Models"
             xmlns:viewmodel="clr-namespace:IDPBookApp.ViewModel"
             x:DataType="viewmodel:LoginViewModel"
             NavigationPage.HasNavigationBar="False"
             Title="LoginPage">
    <ScrollView>
        <Grid
        HorizontalOptions="Fill"
        VerticalOptions="Fill">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Image
                    Aspect="AspectFit"
                    Source="mainidplogo.png" Margin="50,30,50,30" BackgroundColor="Transparent"/>
            <Border
            Grid.Row="1"
            Margin="0,0,0,-50"
            StrokeShape="RoundRectangle 50">
                <Grid
                    Margin="10,0"
                    HorizontalOptions="Fill"
                    RowSpacing="30"
                    VerticalOptions="Fill">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Label
                    Grid.Row="0"
                    FontAttributes="Bold"
                    FontSize="24"
                    HorizontalOptions="Center"
                    Text="Bienvenido"/>
                    <Label
                    Grid.Row="1"
                    Margin="0,-20,0,0"
                    HorizontalOptions="Center"
                    Text="Ingresa con tu cuenta habitual."/>
                    <Entry
                        x:Name="nom"
                    Grid.Row="2"
                    Margin="0,20,0,0"
                    HorizontalOptions="Fill"
                    Placeholder="Correo"
                    Text="{Binding UserName}"
                    VerticalOptions="Fill"
                        Keyboard="Email"/>
                    <Entry
                        x:Name="pas"
                    Grid.Row="3"
                    HorizontalOptions="Fill"
                    IsPassword="{Binding VisPass}"
                    Placeholder="Contraseña"
                    Text="{Binding UserPassword}"
                    VerticalOptions="Fill"/>
                    <CheckBox 
                        Grid.Row="4"
                        IsChecked="{Binding VisPass}"
                        Margin="0" 
                        HorizontalOptions="Start"
                        VerticalOptions="Center"                       
                        IsVisible="{Binding Disable}"/>
                    <Label 
                        Grid.Row="4" 
                        Text="Ocultar contraseña"
                        Margin="40,0,0,0" 
                        VerticalOptions="Center" 
                        IsVisible="{Binding Disable}"/>
                    <Button
                        Grid.Row="5"
                        Command="{Binding LoginBtnCommand}"
                        Pressed="Button_Pressed"
                        CornerRadius="20"
                        FontAttributes="Bold"
                        Text="Ingresar"/>
                    <Button
                        Grid.Row="6"
                        Pressed="Button_Pressed"
                        FontAttributes="Bold"
                        CornerRadius="20"
                        WidthRequest="210"
                        Text="¿Olvidaste tu contraseña?" HorizontalOptions="Center"
                        Command="{Binding ChangePassBtnCommand}"
                    />
                    <HorizontalStackLayout Grid.Row="7" Spacing="50" HorizontalOptions="Center">
                        <Image
                        Aspect="AspectFit"
                        HeightRequest="100"
                        Source="ic_logo_lafe.png"
                        WidthRequest="80" />
                        <Image
                        VerticalOptions="Start"
                        Aspect="AspectFit"
                        HeightRequest="100"
                        Source="ic_logo_umh.png"
                        WidthRequest="80" />
                    </HorizontalStackLayout>
                    <Label
                        Grid.Row="8"
                        FontAttributes="Bold"
                        Text="Contacta con el equipo desarrollador."
                        TextColor="{Binding GrisO}"
                        HorizontalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding DisplayInfoCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                    <ActivityIndicator IsRunning = "{Binding Run}" Margin = "20" Grid.Row="8" HorizontalOptions = "Center" />
                </Grid>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>